# FinanceOS Dashboard — Environment Variables
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local to git.

# ─── Phase 1: Mock data (no Drive connection needed) ─────────────────────────
NEXT_PUBLIC_DATA_SOURCE=mock

# ─── Phase 2: Google Drive connection (server-side only) ─────────────────────
# These are read ONLY inside Next.js API routes (server).
# They are NEVER sent to the browser. NEVER prefix with NEXT_PUBLIC_.
# Set these as Replit Secrets / GitHub Secrets — not in any file.

# Full JSON of a Google service account with Drive read-only scope.
# Generate in Google Cloud Console → IAM → Service Accounts.
GOOGLE_SERVICE_ACCOUNT_JSON=

# ID of the Google Shared Drive containing FinanceOS/.
GOOGLE_SHARED_DRIVE_ID=

# Security boundaries (read-only — leave blank for Phase 1):
# - No QBO access from this app
# - No bank API access from this app
# - Drive access is READ-ONLY (presentation layer only)
