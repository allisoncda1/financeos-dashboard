{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc --build ../../lib/db/tsconfig.json ../../lib/api-zod/tsconfig.json && tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "rc001:backfill:dry": "DRY_RUN=true tsx src/scripts/backfillPayments.ts",
    "rc001:backfill": "tsx src/scripts/backfillPayments.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "bcryptjs": "^3.0.3",
    "speakeasy": "^2.0.0",
    "qrcode": "^1.5.3",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csv-parse": "^7.0.1",
    "drizzle-orm": "catalog:",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "google-auth-library": "^10.9.0",
    "googleapis": "^173.0.0",
    "pg": "^8.22.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "puppeteer": "^25.3.0",
    "@replit/object-storage": "^1.0.0",
    "@google-cloud/storage": "^7.7.0"
  },
  "devDependencies": {
    "@esbuild/darwin-arm64": "^0.28.1",
    "@rollup/rollup-darwin-arm64": "^4.62.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/speakeasy": "^2.0.10",
    "@types/qrcode": "^1.5.5",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.0.0",
    "thread-stream": "3.1.0",
    "tsx": "catalog:",
    "vitest": "^3.0.0"
  }
}
